{
    "manifest_version": 3,
    "name": "Focus Pomodoro",
    "version": "1.0",
    "description": "Pomodoro timer with site blocking for better studying",
    "permissions": ["storage", "alarms", "notifications", "tabs", "declarativeNetRequest"],
    "host_permissions": ["<all_urls>"],
    "background": {
      "service_worker": "background.js"
    },
    "action": {
      "default_popup": "popup.html",
      "default_title": "Focus Pomodoro",
      "default_icon": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png"
      }
    },
    "options_page": "options.html",
    "declarative_net_request": {
      "rule_resources": [
        {
          "id": "blocklist",
          "enabled": true,
          "path": "site-blocklist.json"
        }
      ]
    },
    "icons": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }